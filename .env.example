# ─── LLM Provider ───────────────────────────────────────
#
# v2 supports ONE provider: LM Studio (local, OpenAI-compatible API).
# Cloud providers (Groq, OpenRouter) were removed in v2 because the product
# is positioned as peer-to-peer — your prompts never leave your machine.
# See README.md → "Architecture (v2)" for the rationale.
#
# Download LM Studio: https://lmstudio.ai
# Recommended model:  Qwen2.5-Coder-7B-Instruct (Q4_K_M)

LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=qwen2.5-coder-7b-instruct

# Фактическая длина контекста, загруженная в LM Studio (в токенах). ВАЖНО:
# на 8GB GPU модель часто грузится с 4096 по умолчанию — тогда бюджет генерации,
# рассчитанный на 32k, молча переполняет контекст и обрезает вход (битый вывод).
# Выставь сюда РЕАЛЬНОЕ значение из LM Studio (или включи YaRN до 32k там же).
# По умолчанию 32000.
# LMSTUDIO_CONTEXT_WINDOW=4096

# ─── App ────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Daily limit for guests (anonymous users) per IP
GUEST_DAILY_LIMIT=10

# Set to enable legacy single-user auth — required in production if NOT using Appwrite.
# Leave empty for public dev mode.
NIT_API_SECRET=

# Max concurrent in-flight generations per user (capped across all their tunnels).
# Min 1, max 100. Default: 3.
# NIT_MAX_CONCURRENT_PER_USER=3

# Абсолютный потолок длительности одной генерации (мс). Бэкстоп против «вечного
# висяка», когда модель бесконечно капает токены (reasoning-петля) и idle-таймаут
# (5 мин по реальному контенту) не срабатывает. Мин 60000. Default: 1200000 (20 мин).
# NIT_PENDING_HARD_TIMEOUT_MS=1200000

# ─── Feedback loop (optional) ───────────────────────────
#
# Append-only JSONL of every generation (query → plan → outcome).
# Used for analyzing failed queries, building few-shot corpora, future LoRA fine-tunes.
#
# Default: disabled. For production, recommend:
#   NIT_FEEDBACK_ENABLED=1
#   NIT_FEEDBACK_LOG_PATH=/var/lib/nit/feedback.jsonl
#
# The default /tmp path is LOST on VPS reboot — do not use in production.
NIT_FEEDBACK_ENABLED=0
# NIT_FEEDBACK_LOG_PATH=/var/lib/nit/feedback.jsonl

# ─── Trust proxy (required in production) ───────────────
#
# Comma-separated list of IPs the server TRUSTS for X-Forwarded-For / X-Real-IP /
# CF-Connecting-IP headers. Without this, an attacker can spoof headers to bypass
# rate-limit and guest quota.
#
# Typically your nginx IP (127.0.0.1 if it runs on the same host).
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# ─── Admin endpoints (optional) ─────────────────────────
#
# Protects /api/admin/* (eval, metrics, RAG, guest-limits cleanup).
# If not set, admin endpoints return 503 (fail-secure). Min 8 chars.
# NIT_ADMIN_TOKEN=

# ─── Auth (required in production) ──────────────────────
#
# HMAC key for session cookies AND tunnel-token lookup. Min 32 chars.
# Rotating this invalidates ALL sessions and tunnel tokens.
# Generate: openssl rand -hex 32
# NIT_TOKEN_LOOKUP_SECRET=

# Temporary email-only login bypass while SMTP/Resend is not configured.
# When enabled, /login creates/finds the user by email and immediately sets
# the session cookie without sending a magic-link email.
# NIT_EMAIL_ONLY_LOGIN=0

# ─── Appwrite (production multi-user) ───────────────────
#
# Backend for multi-user auth and "My Sites". Without API_KEY, auth runs in
# single-user mode via NIT_API_SECRET.
# APPWRITE_API_KEY=
# APPWRITE_ENDPOINT=https://appwrite.vibecoding.by/v1
# APPWRITE_PROJECT_ID=69ab07130011752aae12
# APPWRITE_DATABASE_ID=nit_builder

# ─── Tunnel (dev) ───────────────────────────────────────
#
# Token for a local tunnel client when Appwrite isn't configured.
# In production, users get real tunnel-tokens at /api/auth/register.
# NIT_DEV_TUNNEL_TOKEN=

# ─── Постобработка генерации (детерминированные слои) ───
#
# Премиум-база (:where-слой типографики/отступов/фокуса): по умолчанию ON,
# NIT_TUNNEL_POLISH=0 — отключить.
# NIT_TUNNEL_POLISH=1
#
# SEO-голова из плана (description / OpenGraph / Twitter / JSON-LD): по умолчанию
# ON, NIT_TUNNEL_SEO=0 — отключить.
# NIT_TUNNEL_SEO=1
#
# Вау-слой (фирменный акцент для нейтральной ветки generic/clean-saas): по
# умолчанию OFF, NIT_TUNNEL_WOW=1 — включить.
# NIT_TUNNEL_WOW=1
#
# Посекционная оркестрация (план + секции отдельными вызовами): по умолчанию OFF,
# для сильных моделей. NIT_TUNNEL_SECTIONS=1 — включить.
# NIT_TUNNEL_SECTIONS=0

# ─── Публичные превью /p/:token ─────────────────────────
#
# Индексация расшаренных превью в поисковиках. По умолчанию OFF (превью часто
# приватные ссылки для клиента). NIT_PUBLIC_INDEXABLE=1 — разрешить индексацию
# (добавляет index,follow + canonical). Внимание: открывает превью для Google.
# NIT_PUBLIC_INDEXABLE=0

# ─── Картинки в генерации ───────────────────────────────
#
# Битые Unsplash photo-id (модель часто галлюцинирует несуществующие) при
# постобработке автоматически заменяются на picsum.photos (всегда отдаёт фото).
# Для настоящих тематических картинок в будущем — подключить Unsplash API ключ
# (UNSPLASH_ACCESS_KEY, пока не реализовано).
